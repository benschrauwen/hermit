{
  "meta": {
    "name": "hermit",
    "version": "1.0.0",
    "description": "Sandbox profile for running Hermit from a Node/npm workspace"
  },
  "workdir": {
    "access": "readwrite"
  },
  "security": {
    "groups": ["node_runtime", "unlink_protection"]
  },
  "filesystem": {
    "read": ["$HOME/.config/git"],
    "read_file": ["$HOME/.gitconfig"]
  },
  "network": {
    "network_profile": "developer",
    "proxy_allow": [
      "skills.sh",
      "clawhub.ai",
      "api.openai.com",
      "api.anthropic.com",
      "generativelanguage.googleapis.com",
      "openrouter.ai",
      "api.groq.com",
      "api.x.ai",
      "api.mistral.ai",
      "api.cerebras.ai"
    ]
  }
}
