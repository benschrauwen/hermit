# Dependencies
node_modules/

# Build
dist/
*.tsbuildinfo

# Environment and secrets
.env
.env.local
.env.*.local

# Logs and debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE and editors
.idea/
*.swp
*.swo
*~

# Optional: uncomment if you want to keep editor config but ignore local state
# .vscode/*
# !.vscode/settings.json
# !.vscode/extensions.json

# Test and coverage (if added later)
coverage/

# Cursor / plan artifacts (optional; remove if you want to track plans)
.cursor/plans/

# Agent runtime data
agents/*/.role-agent/
agents/*/agent/
agents/*/supporting-files/

# Entity instance data (templates and .gitkeep files are tracked)
entities/company/
entities/people/
entities/deals/active/*/
entities/deals/closed-won/*/
entities/deals/closed-lost/*/
entities/product/*/
entities/tickets/*/
entities/initiatives/*/
!entities/initiatives/.gitkeep
entities/systems/*/
!entities/systems/.gitkeep
entities/incidents/open/*/
!entities/incidents/open/.gitkeep
entities/incidents/resolved/*/
!entities/incidents/resolved/.gitkeep