{
  "name": "leadership-role-agent",
  "version": "0.1.0",
  "description": "Local file-first multi-role leadership agent powered by pi-mono.",
  "type": "module",
  "packageManager": "bun@1.3.8",
  "bin": {
    "leadership-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "bun src/cli.ts",
    "cli": "bun src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "explorer": "bun run build && (cd explorer && WORKSPACE_ROOT=\"$(cd .. && pwd)\" bun run dev)",
    "explorer:build": "bun run build && (cd explorer && WORKSPACE_ROOT=\"$(cd .. && pwd)\" bun run build)",
    "explorer:preview": "(cd explorer && WORKSPACE_ROOT=\"$(cd .. && pwd)\" bun run preview)"
  },
  "keywords": [
    "leadership",
    "roles",
    "agent",
    "pi-mono",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@sinclair/typebox": "^0.34.48",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "gray-matter": "^4.0.3",
    "openai": "^6.27.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
