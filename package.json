{
  "name": "hermit",
  "version": "0.1.0",
  "description": "Local file-first runtime for autonomous applications, powered by pi-mono.",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "postinstall": "npm --prefix explorer install",
    "start": "nono run --profile ./examples/nono/hermit.json --allow-cwd -- npm run start:unsafe --",
    "start:unsafe": "npm run cli -- chat",
    "cli": "node --import tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "heartbeat-daemon": "nono run --profile ./examples/nono/hermit.json --allow-cwd -- npm run heartbeat-daemon:unsafe --",
    "heartbeat-daemon:unsafe": "npm run cli -- heartbeat-daemon",
    "explorer": "NODE_OPTIONS='--import tsx' WORKSPACE_ROOT=\"$(pwd)\" npm --prefix explorer run dev",
    "explorer:build": "NODE_OPTIONS='--import tsx' WORKSPACE_ROOT=\"$(pwd)\" npm --prefix explorer run build",
    "explorer:preview": "NODE_OPTIONS='--import tsx' WORKSPACE_ROOT=\"$(pwd)\" npm --prefix explorer run preview"
  },
  "keywords": [
    "hermit",
    "autonomous-applications",
    "agent",
    "file-first",
    "pi-mono",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@sinclair/typebox": "^0.34.48",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "gray-matter": "^4.0.3",
    "openai": "^6.27.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
