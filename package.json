{
  "name": "sales-leader-agent",
  "version": "0.1.0",
  "description": "Local file-first sales leader agent powered by pi-mono.",
  "type": "module",
  "bin": {
    "sales-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "sales",
    "agent",
    "pi-mono",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-coding-agent": "^0.57.1",
    "@sinclair/typebox": "^0.34.48",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "gray-matter": "^4.0.3",
    "openai": "^6.27.0",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
