---
import "../styles/global.css";

interface Props {
  title: string;
  roleId?: string;
  roleName?: string;
}

const { title, roleId, roleName } = Astro.props;
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Hermit</title>
  </head>
  <body>
    <div class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(14,165,233,0.10),_transparent_34%),linear-gradient(to_bottom,_#f8fafc,_#f1f5f9)]">
      <header class="sticky top-0 z-20 border-b border-white/10 bg-slate-950/90 backdrop-blur">
        <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8">
          <a href="/" class="text-sm font-semibold tracking-[0.12em] text-white no-underline">
            HERMIT
          </a>
          <nav class="flex flex-wrap items-center gap-2">
            <a class="nav-link" href="/">Home</a>
            <a class="nav-link" href="/company">Company</a>
            <a class="nav-link" href="/people">People</a>
            <a class="nav-link" href="/architecture">Architecture</a>
            <a class="nav-link" href="/license">License</a>
            {roleId && (<a class="nav-link" href={`/roles/${roleId}`}>{roleName ?? roleId}</a>)}
          </nav>
        </div>
      </header>
      <main class="page-shell">
        <slot />
      </main>
    </div>
  </body>
</html>
