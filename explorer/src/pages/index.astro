---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readEntityRecordContent } from "../lib/entity-content.js";
import { getPublicPageBySlug, listPublicPages } from "../lib/public-pages.js";
import { getWorkspaceRoot, listRoleIds, loadEntityDefs, scanEntitiesByDefinition } from "../lib/workspace.js";

const root = getWorkspaceRoot();

const { entities: entityDefs } = await loadEntityDefs(root);
const roleIds = await listRoleIds(root);

const siteDef = entityDefs.find((entityDef) => entityDef.type === "site");
const capabilityDef = entityDefs.find((entityDef) => entityDef.type === "capability");

const siteEntity = siteDef ? (await scanEntitiesByDefinition(root, siteDef))[0] : undefined;
const capabilityEntities = capabilityDef ? await scanEntitiesByDefinition(root, capabilityDef) : [];
const allPublicPages = await listPublicPages(root);
const homePage = await getPublicPageBySlug("home", root);

const publicPageOrder = ["getting-started", "architecture", "inside"];
const publicPages = allPublicPages
  .filter((page) => page.slug && page.slug !== "home")
  .sort((left, right) => {
    const leftIndex = publicPageOrder.indexOf(left.slug);
    const rightIndex = publicPageOrder.indexOf(right.slug);
    const normalizedLeft = leftIndex === -1 ? Number.MAX_SAFE_INTEGER : leftIndex;
    const normalizedRight = rightIndex === -1 ? Number.MAX_SAFE_INTEGER : rightIndex;
    return normalizedLeft - normalizedRight || left.name.localeCompare(right.name);
  });

let siteTitle = "Hermit";
let siteDescription = "Hermit is a file-first runtime for autonomous applications.";
let primaryCtaLabel = "Explore capabilities";
let primaryCtaHref = "/entities/capability";
let secondaryCtaLabel = "Read the architecture";
let secondaryCtaHref = "/architecture";

if (siteEntity && siteDef) {
  const files = await readEntityRecordContent(siteEntity.path, siteDef);
  const record = files.find((file) => file.relativePath === "record.md") ?? files[0];
  const frontmatter = record?.frontmatter ?? {};

  siteTitle = typeof frontmatter.name === "string" ? frontmatter.name : siteTitle;
  siteDescription = typeof frontmatter.value_proposition === "string" ? frontmatter.value_proposition : siteDescription;
  primaryCtaLabel = typeof frontmatter.primary_cta_label === "string" ? frontmatter.primary_cta_label : primaryCtaLabel;
  primaryCtaHref = typeof frontmatter.primary_cta_href === "string" ? frontmatter.primary_cta_href : primaryCtaHref;
  secondaryCtaLabel = typeof frontmatter.secondary_cta_label === "string" ? frontmatter.secondary_cta_label : secondaryCtaLabel;
  secondaryCtaHref = typeof frontmatter.secondary_cta_href === "string" ? frontmatter.secondary_cta_href : secondaryCtaHref;
}

const capabilityOrder = [
  "cap-files-are-the-app",
  "cap-local-first-runtime",
  "cap-role-based-operators",
  "cap-explorer-to-website",
];

const capabilityCards = capabilityDef
  ? (
      await Promise.all(
        capabilityEntities.map(async (entity) => {
          const files = await readEntityRecordContent(entity.path, capabilityDef);
          const record = files.find((file) => file.relativePath === "record.md") ?? files[0];
          const frontmatter = record?.frontmatter ?? {};
          return {
            id: entity.id,
            name: entity.name,
            href: `/entities/capability/${entity.id}`,
            headline: typeof frontmatter.headline === "string" ? frontmatter.headline : "",
            summary: typeof frontmatter.value_summary === "string" ? frontmatter.value_summary : "",
            audience: typeof frontmatter.audience === "string" ? frontmatter.audience : "",
          };
        }),
      )
    ).sort((left, right) => {
      const leftIndex = capabilityOrder.indexOf(left.id);
      const rightIndex = capabilityOrder.indexOf(right.id);
      const normalizedLeft = leftIndex === -1 ? Number.MAX_SAFE_INTEGER : leftIndex;
      const normalizedRight = rightIndex === -1 ? Number.MAX_SAFE_INTEGER : rightIndex;
      return normalizedLeft - normalizedRight || left.name.localeCompare(right.name);
    })
  : [];

const homeNarrativeBlocks = homePage?.blocks.filter((block) => !block.relativePath.includes("proof")) ?? [];
const homeProofBlocks = homePage?.blocks.filter((block) => block.relativePath.includes("proof")) ?? [];
---
<BaseLayout title={siteTitle} description={siteDescription}>
  <section class="hero card">
    <div class="hero-copy">
      <p class="hero-kicker">File-first autonomous applications</p>
      <h1>{siteTitle}</h1>
      <p class="hero-lead">{siteDescription}</p>
      <div class="cta-row">
        <a class="button-primary" href={primaryCtaHref}>{primaryCtaLabel}</a>
        <a class="button-secondary" href={secondaryCtaHref}>{secondaryCtaLabel}</a>
      </div>
      <div class="resource-row">
        <a class="github-badge" href="https://github.com/benschrauwen/hermit" target="_blank" rel="noreferrer">
          <span class="github-badge-label">GitHub</span>
          <span class="github-badge-value">benschrauwen/hermit</span>
        </a>
        <a class="resource-link" href="https://benschrauwen.substack.com/p/the-advent-of-autonomous-applications" target="_blank" rel="noreferrer">Read Ben's announcement ↗</a>
      </div>
      <p class="hero-proof-note">Built from roles, records, and renderers in this repo — with the working process visible inside the site.</p>
    </div>
    <div class="hero-visual-shell">
      <img class="hero-mascot" src="/mascot.png" alt="Hermit mascot" />
    </div>
    <div class="hero-stat-grid">
      <div class="stat-card">
        <span class="stat-label">Capabilities</span>
        <strong class="stat-value">{capabilityCards.length}</strong>
      </div>
      <div class="stat-card">
        <span class="stat-label">Public pages</span>
        <strong class="stat-value">{publicPages.length + 1}</strong>
      </div>
      <div class="stat-card">
        <span class="stat-label">Active roles</span>
        <strong class="stat-value">{roleIds.length}</strong>
      </div>
    </div>
  </section>

  {homePage?.publicHtml && (
    <section class="card detail-panel mb-10">
      <div class="markdown-body" set:html={homePage.publicHtml} />
    </section>
  )}

  {homeNarrativeBlocks.length > 0 && (
    <section class="mb-10">
      <div class="section-header">
        <div>
          <p class="section-kicker">How it works</p>
          <h2 class="section-title-large">Why Hermit feels different</h2>
        </div>
      </div>
      <div class="card-grid">
        {homeNarrativeBlocks.map((block) => (
          <section class="card detail-panel">
            <div class="markdown-body" set:html={block.html} />
          </section>
        ))}
      </div>
    </section>
  )}

  {homeProofBlocks.length > 0 && (
    <section class="mb-10">
      <div class="section-header">
        <div>
          <p class="section-kicker">Proof</p>
          <h2 class="section-title-large">A concrete example in this repo</h2>
        </div>
      </div>
      {homeProofBlocks.map((block) => (
        <section class="card detail-panel mb-6">
          <div class="markdown-body" set:html={block.html} />
        </section>
      ))}
    </section>
  )}

  {capabilityCards.length > 0 && (
    <section class="mb-10">
      <div class="section-header">
        <div>
          <p class="section-kicker">Capabilities</p>
          <h2 class="section-title-large">What Hermit can do</h2>
        </div>
        <a class="section-link" href="/entities/capability">See all capabilities</a>
      </div>
      <div class="card-grid">
        {capabilityCards.map((capability) => (
          <a class="feature-card" href={capability.href}>
            <span class="feature-tag">Capability</span>
            <h3>{capability.name}</h3>
            {capability.headline && <p>{capability.headline}</p>}
            {capability.summary && <p class="feature-summary">{capability.summary}</p>}
            {capability.audience && <p class="feature-meta">For {capability.audience}</p>}
          </a>
        ))}
      </div>
    </section>
  )}

  {publicPages.length > 0 && (
    <section class="mb-10">
      <div class="section-header">
        <div>
          <p class="section-kicker">Next steps</p>
          <h2 class="section-title-large">Explore the site</h2>
        </div>
      </div>
      <div class="card-grid compact-grid">
        {publicPages.map((page) => (
          <a class="feature-card compact-card" href={page.href}>
            <span class="feature-tag">Page</span>
            <h3>{page.name}</h3>
            {page.summary && <p>{page.summary}</p>}
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mb-10">
    <div class="section-header">
      <div>
        <p class="section-kicker">Transparency</p>
        <h2 class="section-title-large">Inspect how the site improves itself</h2>
      </div>
    </div>
    <div class="card-grid compact-grid">
      <a class="feature-card compact-card" href="/inside">
        <span class="feature-tag">Inside Hermit</span>
        <h3>Open the internal state</h3>
        <p>See the page records, capability records, active website work, and the route into entities and agents.</p>
      </a>
      <a class="feature-card compact-card" href="/entities/site/site">
        <span class="feature-tag">Site record</span>
        <h3>Read the site strategy</h3>
        <p>Inspect the canonical site record that drives the homepage promise, audience, and calls to action.</p>
      </a>
      <a class="feature-card compact-card" href="/agents/website">
        <span class="feature-tag">Website agent</span>
        <h3>See the current next actions</h3>
        <p>Open the website role's working record and inbox to see how improvements are tracked in files.</p>
      </a>
    </div>
  </section>
</BaseLayout>
