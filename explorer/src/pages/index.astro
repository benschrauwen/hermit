---
import path from "node:path";
import { promises as fs } from "node:fs";
import BaseLayout from "../layouts/BaseLayout.astro";
import { renderExplorerHome } from "../lib/renderers.js";
import { countEntitiesByDefinition, getFrameworkRoot, getWorkspaceRoot, listRoleIds, loadEntityDefs } from "../lib/workspace.js";
import { marked } from "marked";

const root = getWorkspaceRoot();
const frameworkRoot = getFrameworkRoot();

marked.setOptions({ gfm: true });
const readmePath = path.join(frameworkRoot, "README.md");
const readmeRaw = await fs.readFile(readmePath, "utf8").catch((error) => {
  const code = error && typeof error === "object" && "code" in error ? (error as NodeJS.ErrnoException).code : undefined;
  if (code === "ENOENT") {
    return "";
  }
  throw error;
});
const readmeHtml = readmeRaw
  ? (await marked.parse(readmeRaw))
      .replace('src="public/mascot.png"', 'src="/mascot.png"')
      .replace(/href="docs\/architecture\.md"/g, 'href="/architecture"')
      .replace(/href="LICENSE"/g, 'href="/license"')
  : "";

const roleIds = await listRoleIds(root);
const { entities: entityDefs, explorer } = await loadEntityDefs(root);
const entityTypes = await Promise.all(
  entityDefs.map(async (entityDef) => ({
    entityDef,
    count: await countEntitiesByDefinition(root, entityDef),
  })),
);
const hasAgents = roleIds.length > 0;
const hasEntities = entityTypes.some(({ count }) => count > 0);
const customHome = await renderExplorerHome({ root, explorer });
---
<BaseLayout title={customHome?.title ?? "Explorer"}>
  {customHome ? (
    <div set:html={customHome.html} />
  ) : (
    <>
      <div class="page-intro">
        <h1>Explorer</h1>
        <p class="meta">Browse global entities, role workspaces, and shared Hermit docs.</p>
      </div>

      {hasEntities && (
        <>
          <h2 class="section-title">Entities</h2>
          <div class="entity-type-list mb-8">
            <a href="/entities">
              <strong>All Entities</strong>
              <span class="meta"> — browse the workspace entity catalog by type</span>
            </a>
          </div>
        </>
      )}

      {hasAgents && (
        <>
          <h2 class="section-title">Agents</h2>
          <div class="entity-type-list mb-8">
            <a href="/agents">
              <strong>All Agents</strong>
              <span class="meta"> — browse role workspaces and operating contexts</span>
            </a>
          </div>
        </>
      )}

      {readmeHtml && (
        <section class="file-section card mt-10">
          <h3>README</h3>
          <div class="markdown-body" set:html={readmeHtml} />
        </section>
      )}
    </>
  )}
</BaseLayout>
