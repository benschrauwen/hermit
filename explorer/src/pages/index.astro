---
import path from "node:path";
import { promises as fs } from "node:fs";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getWorkspaceRoot } from "../lib/workspace.js";
import { marked } from "marked";

const root = getWorkspaceRoot();

marked.setOptions({ gfm: true });
const readmePath = path.join(root, "README.md");
const readmeRaw = await fs.readFile(readmePath, "utf8").catch(() => "");
const readmeHtml = readmeRaw
  ? (await marked.parse(readmeRaw))
      .replace('src="public/mascot.png"', 'src="/mascot.png"')
      .replace(/href="docs\/architecture\.md"/g, 'href="/architecture"')
      .replace(/href="LICENSE"/g, 'href="/license"')
  : "";
---
<BaseLayout title="Explorer">
  <div class="page-intro">
    <h1>Explorer</h1>
    <p class="meta">Browse global entities, role workspaces, and shared Hermit docs.</p>
  </div>

  <h2 class="section-title">Entities</h2>
  <div class="entity-type-list mb-8">
    <a href="/entities">
      <strong>All Entities</strong>
      <span class="meta"> — browse the global entity catalog by type</span>
    </a>
  </div>

  <h2 class="section-title">Agents</h2>
  <div class="entity-type-list mb-8">
    <a href="/agents">
      <strong>All Agents</strong>
      <span class="meta"> — browse role workspaces and operating contexts</span>
    </a>
  </div>

  <h2 class="section-title">Docs</h2>
  <div class="entity-type-list mb-8">
    <a href="/architecture">
      <strong>Architecture</strong>
      <span class="meta"> — design document for the Hermit runtime</span>
    </a>
    <a href="/license">
      <strong>License</strong>
      <span class="meta"> — MIT license</span>
    </a>
  </div>

  {readmeHtml && (
    <section class="file-section card mt-10">
      <h3>README</h3>
      <div class="markdown-body" set:html={readmeHtml} />
    </section>
  )}
</BaseLayout>
