---
import path from "node:path";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { readMarkdownFiles } from "../../../../lib/entity-content.js";
import { getWorkspaceRoot, loadRole } from "../../../../lib/workspace.js";
import { marked } from "marked";

const { roleId } = Astro.params;
if (!roleId) return Astro.redirect("/");

const root = getWorkspaceRoot();
let role;
try {
  role = await loadRole(root, roleId);
} catch {
  return Astro.redirect("/");
}

const agentDir = path.join(role.roleDir, "agent");

marked.setOptions({ gfm: true });
const files = await Promise.all(
  (await readMarkdownFiles(agentDir, ["record.md", "inbox.md"])).map(async (file) => ({
    ...file,
    html: file.content ? await marked.parse(file.content) : "",
  })),
);
---
<BaseLayout title={`Agent Workspace · ${role.name}`} roleId={roleId} roleName={role.name}>
  <div class="breadcrumb">
    <a href={`/agents/${roleId}`}>{role.name}</a> → Agent Workspace
  </div>
  <h1>Agent Workspace</h1>
  <p class="meta">Internal operating-system files for the `{roleId}` role.</p>

  {files.map((file) => (
    <section class="file-section card">
      <h3>{file.relativePath}</h3>
      {Object.keys(file.frontmatter).length > 0 && (
        <dl class="meta" style="margin: 0 0 0.75rem; font-size: 0.85rem;">
          {Object.entries(file.frontmatter).map(([k, v]) => [
            <dt style="margin: 0.25rem 0 0; font-weight: 600;">{k}</dt>,
            <dd style="margin: 0 0 0 1rem;">{Array.isArray(v) ? v.join(", ") : String(v)}</dd>,
          ])}
        </dl>
      )}
      <div class="markdown-body" set:html={file.html} />
    </section>
  ))}
</BaseLayout>
