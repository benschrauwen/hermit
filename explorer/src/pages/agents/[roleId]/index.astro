---
import path from "node:path";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { readMarkdownFiles } from "../../../lib/entity-content.js";
import { renderDefaultFileSection } from "../../../lib/renderers.js";
import { getWorkspaceRoot, loadRole } from "../../../lib/workspace.js";

const { roleId } = Astro.params;
if (!roleId) return Astro.redirect("/");

const root = getWorkspaceRoot();
const role = await loadRole(root, roleId);

const agentDir = path.join(role.roleDir, "agent");
const sections = await Promise.all(
  (await readMarkdownFiles(agentDir, ["record.md", "inbox.md"])).map((file) => renderDefaultFileSection(file)),
);
---
<BaseLayout title={role.name} roleId={roleId} roleName={role.name}>
  <div class="breadcrumb">
    <a href="/">Explorer</a> →
    <a href="/agents">Agents</a> →
    {role.name}
  </div>
  <div class="page-intro">
    <h1>{role.name}</h1>
    <p class="meta">{role.description}</p>
  </div>

  {sections.map((section) => (
    <div set:html={section} />
  ))}
</BaseLayout>
