---
import { promises as fs } from "node:fs";
import path from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readEntityFrontmatter } from "../../lib/entity-content.js";
import { getWorkspaceRoot } from "../../lib/workspace.js";

const root = getWorkspaceRoot();
const peopleDir = path.join(root, "people");

const entries = await fs.readdir(peopleDir, { withFileTypes: true });
const people = (
  await Promise.all(
    entries
      .filter((entry) => entry.isDirectory())
      .map(async (entry) => {
        const personPath = path.join(peopleDir, entry.name);
        const frontmatter = await readEntityFrontmatter(personPath);
        return {
          id: String(frontmatter.id ?? entry.name),
          name: String(frontmatter.name ?? entry.name),
          status: String(frontmatter.status ?? ""),
          owner: String(frontmatter.owner ?? ""),
        };
      }),
  )
).sort((left, right) => left.name.localeCompare(right.name));
---
<BaseLayout title="People">
  <div class="breadcrumb">
    <a href="/">Explorer</a> → People
  </div>
  <div class="page-intro">
    <h1>People</h1>
    <p class="meta">{people.length} record{people.length !== 1 ? "s" : ""}</p>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>ID</th>
          <th>Status</th>
          <th>Owner</th>
        </tr>
      </thead>
      <tbody>
        {people.map((person) => (
          <tr>
            <td><a href={`/people/${person.id}`}>{person.name}</a></td>
            <td class="meta">{person.id}</td>
            <td>{person.status || "—"}</td>
            <td>{person.owner || "—"}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</BaseLayout>
