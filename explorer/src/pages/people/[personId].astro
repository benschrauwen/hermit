---
import { existsSync } from "node:fs";
import path from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readMarkdownFiles } from "../../lib/entity-content.js";
import { getWorkspaceRoot } from "../../lib/workspace.js";
import { marked } from "marked";

const { personId } = Astro.params;
if (!personId) return Astro.redirect("/people");

const root = getWorkspaceRoot();
const personDir = path.join(root, "people", personId);
if (!existsSync(personDir)) return Astro.redirect("/people");

marked.setOptions({ gfm: true });
const files = await Promise.all(
  (await readMarkdownFiles(personDir)).map(async (file) => ({
    ...file,
    html: file.content ? await marked.parse(file.content) : "",
  })),
);

const record = files.find((file) => file.relativePath === "record.md");
const personName = String(record?.frontmatter.name ?? personId);
---
<BaseLayout title={personName}>
  <div class="breadcrumb">
    <a href="/">Explorer</a> →
    <a href="/people">People</a> →
    {personName}
  </div>
  <div class="page-intro">
    <h1>{personName}</h1>
    <p class="meta">ID: {personId}</p>
  </div>

  {files.map((file) => (
    <section class="file-section card">
      <h3>{file.relativePath}</h3>
      {Object.keys(file.frontmatter).length > 0 && (
        <dl class="meta-list">
          {Object.entries(file.frontmatter).map(([k, v]) => [
            <dt>{k}</dt>,
            <dd>{Array.isArray(v) ? v.join(", ") : String(v)}</dd>,
          ])}
        </dl>
      )}
      <div class="markdown-body" set:html={file.html} />
    </section>
  ))}
</BaseLayout>
