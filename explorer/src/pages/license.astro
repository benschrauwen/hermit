---
import path from "node:path";
import { promises as fs } from "node:fs";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getFrameworkRoot } from "../lib/workspace.js";

const frameworkRoot = getFrameworkRoot();
const filePath = path.join(frameworkRoot, "LICENSE");
const content = await fs.readFile(filePath, "utf8").catch(() => "");
---
<BaseLayout title="License">
  <div class="breadcrumb">
    <a href="/">Explorer</a> → License
  </div>
  <div class="page-intro">
    <h1>License</h1>
  </div>
  {content ? (
    <section class="file-section card">
      <pre class="plain-pre">{content}</pre>
    </section>
  ) : (
    <p>File not found.</p>
  )}
</BaseLayout>
