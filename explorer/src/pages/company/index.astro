---
import path from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readMarkdownFiles } from "../../lib/entity-content.js";
import { getWorkspaceRoot } from "../../lib/workspace.js";
import { marked } from "marked";

const root = getWorkspaceRoot();
const companyDir = path.join(root, "company");

marked.setOptions({ gfm: true });
const files = await Promise.all(
  (await readMarkdownFiles(companyDir)).map(async (file) => ({
    ...file,
    html: file.content ? await marked.parse(file.content) : "",
  })),
);

const record = files.find((file) => file.relativePath === "record.md");
const companyName = String(record?.frontmatter.name ?? "Company");
---
<BaseLayout title={companyName}>
  <div class="breadcrumb">
    <a href="/">Explorer</a> → Company
  </div>
  <h1>{companyName}</h1>
  <p class="meta">{files.length} markdown file{files.length !== 1 ? "s" : ""}</p>

  {files.map((file) => (
    <section class="file-section card">
      <h3>{file.relativePath}</h3>
      {Object.keys(file.frontmatter).length > 0 && (
        <dl class="meta" style="margin: 0 0 0.75rem; font-size: 0.85rem;">
          {Object.entries(file.frontmatter).map(([k, v]) => [
            <dt style="margin: 0.25rem 0 0; font-weight: 600;">{k}</dt>,
            <dd style="margin: 0 0 0 1rem;">{Array.isArray(v) ? v.join(", ") : String(v)}</dd>,
          ])}
        </dl>
      )}
      <div class="markdown-body" set:html={file.html} />
    </section>
  ))}
</BaseLayout>
