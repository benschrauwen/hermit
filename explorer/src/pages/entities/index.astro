---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { countGlobalEntitiesByDefinition, getEntityTypeHref } from "../../lib/entities.js";
import { getWorkspaceRoot, loadEntityDefs } from "../../lib/workspace.js";

const root = getWorkspaceRoot();
const { entities: entityDefs } = await loadEntityDefs(root);
const entityTypes = await Promise.all(
  entityDefs.map(async (entityDef) => ({
    entityDef,
    count: await countGlobalEntitiesByDefinition(root, entityDef),
  })),
);
---
<BaseLayout title="Entities">
  <div class="breadcrumb">
    <a href="/">Explorer</a> → Entities
  </div>
  <div class="page-intro">
    <h1>Entities</h1>
    <p class="meta">{entityTypes.length} type{entityTypes.length !== 1 ? "s" : ""} defined globally</p>
  </div>

  <div class="entity-type-list">
    {entityTypes.map(({ entityDef, count }) => (
      <a href={getEntityTypeHref(entityDef)}>
        <strong>{entityDef.label}</strong>
        <span class="meta"> — {count} record{count !== 1 ? "s" : ""}</span>
      </a>
    ))}
  </div>
</BaseLayout>
