---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { readEntityRecordContent } from "../../../lib/entity-content.js";
import { renderRoleEntityDetail } from "../../../lib/renderers.js";
import { getWorkspaceRoot, loadEntityDefs, scanEntitiesByDefinition } from "../../../lib/workspace.js";

const { entityType, entityId } = Astro.params;
if (!entityType || !entityId) return Astro.redirect("/entities");

const root = getWorkspaceRoot();
const { entities: entityDefs, explorer } = await loadEntityDefs(root);
const entityDef = entityDefs.find((entity) => entity.type === entityType);
if (!entityDef) return Astro.redirect("/entities");

const entities = await scanEntitiesByDefinition(root, entityDef);
const entity = entities.find((candidate) => candidate.id === entityId);
if (!entity) return Astro.redirect(`/entities/${entityType}`);

const files = await readEntityRecordContent(entity.path, entityDef);
const rendered = await renderRoleEntityDetail({
  root,
  explorer,
  entityType,
  entityDef,
  entity,
  files,
});
---
<BaseLayout title={entity.name}>
  <div class="breadcrumb">
    <a href="/">Explorer</a> →
    <a href="/entities">Entities</a> →
    <a href={`/entities/${entityType}`}>{entityDef.label}</a> →
    {entity.name}
  </div>
  <div class="page-intro">
    <h1>{entity.name}</h1>
    <p class="meta">ID: {entity.id} · Type: {entity.type}</p>
  </div>

  {rendered.mode === "detail-plugin" ? (
    <div set:html={rendered.html} />
  ) : (
    rendered.sections.map((section) =>
      <div set:html={section.html} />
    )
  )}
</BaseLayout>
